{
  "expo": {
    "name": "TikDownloaderCOL",
    "slug": "video-downloader-col",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "videosaver",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Necesitamos acceso para guardar los videos descargados en tu galería.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso para guardar los videos descargados en tu galería."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#030508",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "permissions": [
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.ediinxon.videodownloader"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#030508"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "Necesitamos acceso para guardar los videos descargados.",
          "savePhotosPermission": "Necesitamos acceso para guardar los videos descargados.",
          "saveAudioPermission": "Necesitamos acceso para guardar los videos descargados.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-font",
      "expo-video"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cc5d164e-2f7d-4d3f-9128-6ba0a7a6d003"
      }
    },
    "owner": "ediinxon"
  }
}
